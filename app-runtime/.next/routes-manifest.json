{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/pwa-icon-192.png",
        "destination": "/pwa-icon-192",
        "regex": "^/pwa-icon-192\\.png(?:/)?$"
      },
      {
        "source": "/pwa-icon-512.png",
        "destination": "/pwa-icon-512",
        "regex": "^/pwa-icon-512\\.png(?:/)?$"
      },
      {
        "source": "/apple-icon.png",
        "destination": "/apple-icon",
        "regex": "^/apple-icon\\.png(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/catalog/[slug]",
      "regex": "^/catalog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/catalog/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/product/[slug]",
      "regex": "^/product/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
